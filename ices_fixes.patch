diff --git a/src/frontend/src/hooks/use-api.ts b/src/frontend/src/hooks/use-api.ts
index aaa0d4d..2b56349 100644
--- a/src/frontend/src/hooks/use-api.ts
+++ b/src/frontend/src/hooks/use-api.ts
@@ -11,11 +11,16 @@ function getToken(): string | null {
   return localStorage.getItem("ices_token");
 }
 
+const BACKEND_URL = (import.meta.env.VITE_API_URL || "").replace(/\/$/, "");
+
 function normalizeEndpoint(endpoint: string): string {
-  // Accept both "/api/v1/..." and relative "/dashboard/..." or "/dashboard/..."
-  if (endpoint.startsWith("/api/")) return endpoint;
-  if (endpoint.startsWith("/")) return `/api/v1${endpoint}`;
-  return `/api/v1/${endpoint}`;
+  // Build full URL using VITE_API_URL in production, or relative path in dev
+  let path: string;
+  if (endpoint.startsWith("/api/")) path = endpoint;
+  else if (endpoint.startsWith("/")) path = `/api/v1${endpoint}`;
+  else path = `/api/v1/${endpoint}`;
+
+  return BACKEND_URL ? `${BACKEND_URL}${path}` : path;
 }
 
